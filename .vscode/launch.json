{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: Go (Debug)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/backend",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PORT": "3001",
        "DATABASE_URL": "file:./dev.db",
        "STORAGE_TYPE": "local",
        "UPLOAD_DIR": "uploads"
      },
      "args": []
    },
    {
      "name": "Backend: Go (Run)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/backend",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PORT": "3001",
        "DATABASE_URL": "file:./dev.db",
        "STORAGE_TYPE": "local",
        "UPLOAD_DIR": "uploads"
      },
      "noDebug": true
    },
    {
      "name": "Frontend: Vite Dev",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "cwd": "${workspaceFolder}/web",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "Local:.*http://localhost:([0-9]+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    }
  ],
  "compounds": [
    {
      "name": "Full Stack (Backend + Frontend)",
      "configurations": ["Backend: Go (Run)", "Frontend: Vite Dev"],
      "stopAll": true,
      "presentation": {
        "hidden": false,
        "group": "Full Stack",
        "order": 1
      }
    }
  ]
}
