# 数据库
DATABASE_URL="file:./dev.db"

# 存储类型: local | s3
STORAGE_TYPE=local

# 本地存储配置（STORAGE_TYPE=local 时生效）
UPLOAD_DIR=uploads

# S3/OSS 配置（STORAGE_TYPE=s3 时生效）
S3_BUCKET=baby-log-uploads
S3_REGION=us-east-1
S3_ENDPOINT=                    # 自定义端点，如阿里云 OSS: https://oss-cn-hangzhou.aliyuncs.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=                  # 公开访问 URL 前缀，如: https://your-bucket.oss-cn-hangzhou.aliyuncs.com
S3_FORCE_PATH_STYLE=false       # MinIO 等兼容 S3 服务需设为 true
