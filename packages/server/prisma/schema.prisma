generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  username    String   @unique
  password    String
  displayName String
  role        String   @default("user") // admin | user
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  babies            BabyMember[]
  records           Record[]
  plans             Plan[]
  pushSubscriptions PushSubscription[]
}

model Baby {
  id        String   @id @default(uuid())
  name      String
  gender    String
  birthDate DateTime
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members    BabyMember[]
  records    Record[]
  plans      Plan[]
  growths    GrowthRecord[]
  milestones Milestone[]
  reminders  Reminder[]
}

model BabyMember {
  id     String @id @default(uuid())
  userId String
  babyId String
  role   String @default("admin") // admin | editor | viewer

  user User @relation(fields: [userId], references: [id])
  baby Baby @relation(fields: [babyId], references: [id])

  @@unique([userId, babyId])
}

model Record {
  id         String   @id @default(uuid())
  babyId     String
  category   String
  type       String
  data       String   // JSON string
  occurredAt DateTime
  note       String?
  images     String?  // JSON array of URLs
  createdBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  baby Baby @relation(fields: [babyId], references: [id])
  user User @relation(fields: [createdBy], references: [id])

  @@index([babyId, occurredAt])
  @@index([babyId, category])
}

model Plan {
  id          String   @id @default(uuid())
  babyId      String
  title       String
  type        String
  scheduledAt DateTime
  description String?
  reminder    String?
  repeat      String   @default("none")
  status      String   @default("pending")
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  baby Baby @relation(fields: [babyId], references: [id])
  user User @relation(fields: [createdBy], references: [id])

  @@index([babyId, scheduledAt])
  @@index([babyId, status])
}

model GrowthRecord {
  id                String   @id @default(uuid())
  babyId            String
  date              DateTime
  height            Float?
  weight            Float?
  headCircumference Float?
  note              String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  baby Baby @relation(fields: [babyId], references: [id])

  @@index([babyId, date])
}

model Milestone {
  id          String   @id @default(uuid())
  babyId      String
  type        String
  title       String
  occurredAt  DateTime
  description String?
  images      String?  // JSON array of URLs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  baby Baby @relation(fields: [babyId], references: [id])

  @@index([babyId, occurredAt])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Reminder {
  id        String   @id @default(uuid())
  babyId    String
  remindAt  DateTime
  source    String   @default("feeding_auto") // feeding_auto | feeding_manual | plan
  title     String   @default("")
  body      String   @default("")
  refId     String?  // optional reference to plan or record ID
  sent      Boolean  @default(false)
  createdAt DateTime @default(now())

  baby Baby @relation(fields: [babyId], references: [id])

  @@index([sent, remindAt])
  @@index([babyId, source])
}
